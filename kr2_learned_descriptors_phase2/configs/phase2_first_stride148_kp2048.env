SCENE_NAME=scene_09_superpoint_lightglue_stride148_kp2048
IMAGE_DIR=data/scene_08_20260317_first_loop_then_stride4/first_loop_segment/keyframes_stride4_approx250/rgb
OUTPUT_DIR=kr2_learned_descriptors_phase2/outputs/scene_09_superpoint_lightglue_stride148_kp2048

# First parameter set.
PAIR_STRIDES=1,4,8
MAX_PAIRS_PER_STRIDE=0

# Learned feature frontend.
FEATURE_EXTRACTOR=superpoint
MATCHER=lightglue
MAX_KEYPOINTS=2048
DEVICE=auto

# Geometry check after learned matching.
MIN_MATCHES_FOR_GEOMETRY=8
RANSAC_REPROJ_THRESHOLD=1.5
RANSAC_CONFIDENCE=0.999

# Visualization control. 0 means save every pair visualization.
MAX_VISUALIZATIONS=80

# Keep every rerun archived before overwriting this parameter-set directory.
ARCHIVE_PREVIOUS_OUTPUTS=1
